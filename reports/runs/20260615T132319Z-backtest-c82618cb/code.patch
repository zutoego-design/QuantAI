+        )
+        return pd.DataFrame(
+            [
+                [101.0, 101.0, 101.0, 101.0, 101.0, 100],
+                [103.02, 103.02, 103.02, 103.02, 103.02, 100],
+            ],
+            index=pd.to_datetime(["2025-01-02", "2025-01-03"]),
+            columns=columns,
+        ).rename_axis("Date")
+
+    monkeypatch.setattr(YFinancePriceProvider, "fetch", fake_fetch)
