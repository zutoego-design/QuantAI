+    )
+
+    saved = pd.read_parquet(
+        tmp_path / "silver" / "prices" / "prices_daily.parquet"
+    ).sort_values("date")
+    returns = saved.set_index("date")["return_1d"]
+    assert returns.loc[pd.Timestamp("2025-01-02")] == pytest.approx(0.01)
