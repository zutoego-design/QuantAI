+            "date": pd.to_datetime(["2025-01-01", "2025-01-02"]),
+            "open": [100.0, 101.0],
+            "high": [100.0, 101.0],
+            "low": [100.0, 101.0],
+            "close": [100.0, 101.0],
+            "adj_close": [100.0, 101.0],
+            "volume": [100, 100],
+            "return_1d": [pd.NA, 0.01],
+            "source": ["yfinance", "yfinance"],
+            "quality_status": ["live", "live"],
+            "ingestion_time": [pd.Timestamp("2025-01-02")] * 2,
+        }
